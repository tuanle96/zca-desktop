  "knownRisks": [
    {
      "id": "qr-imei-not-persisted-stable",
      "severity": "low",
      "description": "credentials_from_qr generates a fresh imei via generate_zalo_uuid per QR flow. Now that secure-cred-store persists the issued credential triple (incl. imei) per account, the persisted imei is reused on restore; a brand-new QR scan still mints a new device imei (ADR-0004 letter).",
      "disposition": "accepted",
      "owner": "project-owner",
      "acceptedBy": "advisor",
      "acceptanceReason": "ADR-0004 defers upstream device-imei emission; the persisted-credential path (secure-cred-store) reuses the imei on re-login, which covers the stability goal for restored accounts.",
      "mitigation": "secure-cred-store persists and reuses the per-account credential (incl. imei) on restore; a fresh scan minting a new imei is acceptable for a new device identity.",
      "acceptedUntil": "2026-09-01T00:00:00.000Z"
    }
  ],
