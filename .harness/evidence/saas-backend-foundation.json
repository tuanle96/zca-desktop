    },
    {
      "id": "production-email-deferred",
      "severity": "low",
      "description": "Production email now has a configurable magic-link webhook delivery hook; choosing and operating the actual provider credentials is tracked by cloud-auth-devices.",
      "disposition": "accepted",
      "owner": "tuanle96",
      "acceptedBy": "codex",
      "acceptanceReason": "Production email delivery is explicitly out of scope for the foundation and tracked by cloud-auth-devices.",
      "mitigation": "When dev token return is disabled, /auth/magic-link/request requires ZCA_CLOUD_MAGIC_LINK_WEBHOOK_URL and fails with service_unavailable if delivery is not configured."
    },
    {
      "id": "confidential-at-rest-not-e2e",
      "severity": "high",
      "description": "Session-host architecture means the backend worker sees plaintext at runtime; ADR-0006 documents this as confidential-at-rest rather than true E2E.",
      "disposition": "accepted",
      "owner": "tuanle96",
      "acceptedBy": "codex",
      "acceptanceReason": "ADR-0006 records the session-host trust boundary; true server-blind E2E requires a different architecture and is not claimed here.",
      "mitigation": "Sensitive rows/blobs are encrypted at rest and logs/API responses avoid plaintext Zalo credentials; wording consistently says confidential-at-rest, not true E2E.",
      "acceptedUntil": "2026-07-03"
    }
