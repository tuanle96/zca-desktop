  "knownRisks": [
    {
      "id": "message-plaintext-at-rest",
      "severity": "medium",
      "description": "Message bodies are stored in SQLite as plaintext (user data on the user's own machine, not a bearer token). Credentials are encrypted; message text is not, in this iteration.",
      "disposition": "accepted",
      "owner": "project-owner",
      "acceptedBy": "advisor",
      "acceptanceReason": "ADR-0005 prioritizes durability of messages; the credential (the bearer token) is encrypted at rest. Whole-DB encryption is deferred to a future ADR.",
      "mitigation": "Track SQLCipher / whole-DB encryption as a future ADR; the credential master key already protects the high-value secret.",
      "acceptedUntil": "2026-09-01T00:00:00.000Z"
    },
    {
      "id": "keychain-key-loss",
      "severity": "medium",
      "description": "If the OS keychain master key is lost (e.g. OS reinstall), stored credentials become undecryptable and those accounts need a fresh QR scan.",
      "disposition": "accepted",
      "owner": "project-owner",
      "acceptedBy": "advisor",
      "acceptanceReason": "This is the correct security posture (ADR-0005): a leaked DB without the keychain key is not a session leak. Re-scan is a low-cost recovery.",
      "mitigation": "load_accounts skips undecryptable rows and the account is surfaced as reauth-needed for a re-scan rather than crashing."
    }
  ],
  "updatedAt": "2026-06-03T00:39:25.092Z"
