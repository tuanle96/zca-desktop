    "knownRisks": [
        {
            "id": "directory-only-thread-not-backfilled",
            "severity": "low",
            "description": "Backfill only enriches threads that already exist as conversations. A contact/group the user has never exchanged a message with has no thread row, so its avatar is not persisted (it is still resolved live from the directory when the UI needs it).",
            "disposition": "accepted",
            "owner": "project-owner",
            "acceptedBy": "advisor",
            "acceptanceReason": "The bug is about conversation history showing the wrong/blank identity after restart; that only concerns threads that exist. Persisting the entire directory as its own table is a separate, larger slice and an explicit non-goal here.",
            "mitigation": "If a persisted full directory is needed later, add a contacts/groups table and resolve identity from it at load_history time."
        }
    ],
