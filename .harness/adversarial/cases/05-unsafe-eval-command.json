{
  "schemaVersion": 1,
  "id": "unsafe-eval-command",
  "title": "Eval acceptance checks cannot use destructive publish commands",
  "failureMode": "unsafe-command",
  "severity": "high",
  "probe": "eval-task-unsafe-command",
  "prevention": {
