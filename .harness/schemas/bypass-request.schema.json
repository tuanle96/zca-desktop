{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tuanle96/agent-harness-kit/main/src/templates/.harness/schemas/bypass-request.schema.json",
  "title": "agent-harness-kit bypass request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "reason", "scope", "requestedBy", "expiresAt"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^bypass-[a-z0-9][a-z0-9._-]*$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(command|edit|tool|rule|hook|prompt):.+$"
      }
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "approvedBy": {
      "type": "string",
      "minLength": 1
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "usedByRunId": {
      "type": "string",
      "minLength": 1
    }
  }
}
