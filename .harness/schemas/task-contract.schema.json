{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tuanle96/agent-harness-kit/main/src/templates/.harness/schemas/task-contract.schema.json",
  "title": "agent-harness-kit task contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "riskTier", "scope", "acceptance", "permissions", "doneRequires", "evidencePath"],
  "allOf": [
    {
      "if": {
        "properties": {
          "riskTier": { "const": "high-risk" }
        }
      },
      "then": {
        "required": ["permissions"],
        "properties": {
          "permissions": {
            "required": ["allow"],
            "properties": {
              "allow": {
                "minItems": 1,
                "allOf": [
                  {
                    "not": {
                      "contains": {
                        "enum": [
                          "*",
                          "Bash(*)",
                          "Bash(git*)",
                          "Bash(git:*)",
                          "Bash(gh*)",
                          "Bash(gh:*)",
                          "Bash(node*)",
                          "Bash(node:*)"
                        ]
                      }
                    }
                  }
                ]
              }
            }
          },
          "scope": {
            "required": ["allowedLayers"],
            "properties": {
              "allowedLayers": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "properties": {
        "doneRequires": {
          "contains": { "const": "evidence-bundle" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requiresAdr": { "const": true }
        },
        "required": ["requiresAdr"]
      },
      "then": {
        "properties": {
          "doneRequires": { "contains": { "const": "review" } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requiredReviewers": { "type": "array", "minItems": 1 }
        },
        "required": ["requiredReviewers"]
      },
      "then": {
        "properties": {
          "doneRequires": { "contains": { "const": "review" } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "doneRequires": { "contains": { "const": "review" } }
        },
        "required": ["doneRequires"]
      },
      "then": {
        "required": ["requiredReviewers"],
        "properties": {
          "requiredReviewers": { "minItems": 1 }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "type": {
      "enum": ["feature", "bugfix", "refactor", "release", "docs", "harness"]
    },
    "riskTier": {
      "enum": ["tiny", "normal", "high-risk"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "nonGoals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "allowedLayers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "description": "Acceptance criteria for the task. Each id must be stable, lowercase, and unique within this task contract; task-evidence-check enforces uniqueness by id.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "verification"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "anyOf": [
              { "required": ["command"] },
              { "required": ["artifact"] },
              { "required": ["manual"] }
            ],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\s*(?:TBD|TODO|todo|tbd|N/A|n/a|NA|na|fill me|replace me)\\s*$).+"
              },
              "artifact": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\s*(?:TBD|TODO|todo|tbd|N/A|n/a|NA|na|fill me|replace me)\\s*$).+"
              },
              "manual": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\s*(?:TBD|TODO|todo|tbd|N/A|n/a|NA|na|fill me|replace me)\\s*$).+"
              }
            }
          }
        }
      }
    },
    "requiresAdr": {
      "type": "boolean",
      "default": false
    },
    "requiredReviewers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "uniqueItems": true,
      "default": []
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "description": "Task-scoped tool policy. Deny rules always block. A non-empty allow list restricts tools for this task in addition to skill policy.",
      "required": ["allow"],
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true,
          "default": ["Read", "Grep", "Glob", "LS"]
        },
        "deny": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "doneRequires": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["structural", "lint", "tests", "smoke", "ui", "review", "evidence-bundle"]
      },
      "uniqueItems": true
    },
    "evidencePath": {
      "type": "string",
      "pattern": "^(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "default": ".harness/evidence/<id>.json"
    }
  }
}
