{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tuanle96/agent-harness-kit/main/src/templates/.harness/schemas/runtime-parity-report.schema.json",
  "title": "agent-harness-kit runtime parity report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "mode",
    "generatedAt",
    "scores",
    "capabilities",
    "experimental",
    "evidence",
    "surface",
    "errors",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["passed", "failed"] },
    "mode": { "enum": ["kit-source", "installed"] },
    "generatedAt": { "type": "string", "format": "date-time" },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claude", "codex", "kiro"],
      "properties": {
        "claude": { "$ref": "#/$defs/score" },
        "codex": { "$ref": "#/$defs/score" },
        "kiro": { "$ref": "#/$defs/score" }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    },
    "experimental": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "runtime": { "enum": ["claude", "codex", "kiro"] },
          "status": { "$ref": "#/$defs/runtimeStatus" },
          "notes": { "type": "string", "minLength": 1 },
          "promotionCriteria": { "$ref": "#/$defs/stringList" },
          "nextSteps": { "$ref": "#/$defs/stringList" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "total", "verified", "upstream", "missing"],
      "properties": {
        "mode": { "enum": ["verified-local-tests", "upstream-kit-tests"] },
        "total": { "type": "integer", "minimum": 0 },
        "verified": { "type": "integer", "minimum": 0 },
        "upstream": { "type": "integer", "minimum": 0 },
        "missing": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceItem" }
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["source", "installed"] }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "possible", "percent"],
      "properties": {
        "score": { "type": "number", "minimum": 0 },
        "possible": { "type": "integer", "minimum": 0 },
        "percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pass", "partial", "fail", "na"],
          "properties": {
            "pass": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "fail": { "type": "integer", "minimum": 0 },
            "na": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "claude", "codex", "kiro", "notes", "evidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "claude": { "$ref": "#/$defs/runtimeStatus" },
        "codex": { "$ref": "#/$defs/runtimeStatus" },
        "kiro": { "$ref": "#/$defs/runtimeStatus" },
        "notes": { "type": "string", "minLength": 1 },
        "promotionCriteria": { "$ref": "#/$defs/stringList" },
        "nextSteps": { "$ref": "#/$defs/stringList" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidenceItem" }
        }
      }
    },
    "runtimeStatus": {
      "enum": ["pass", "partial", "fail", "n/a"]
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "status"],
      "properties": {
        "capability": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "path": { "type": "string" },
        "contains": { "type": "string" },
        "status": { "enum": ["verified", "upstream", "missing"] },
        "detail": { "type": "string" }
      }
    }
  }
}
