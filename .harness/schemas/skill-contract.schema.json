{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Contract",
  "description": "Schema for agent-harness-kit skill contracts",
  "type": "object",
  "required": ["id", "version", "description", "capabilities"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique skill identifier (kebab-case)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Clear description of what the skill does"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "generation",
          "workflow",
          "analysis",
          "evaluation",
          "observability",
          "refactoring",
          "testing",
          "documentation",
          "orchestration",
          "memory",
          "registry",
          "project-management",
          "reporting"
        ]
      },
      "description": "Skill capability tags"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed tool patterns"
        },
        "deny": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Denied tool patterns"
        }
      },
      "required": ["allow", "deny"]
    },
    "workflow": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "required", "description"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "required": {
                "type": "boolean"
              },
              "description": {
                "type": "string",
                "minLength": 5
              }
            }
          }
        }
      },
      "required": ["steps"]
    },
    "suggestedTurns": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Estimated turns for typical completion"
    },
    "model": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"],
      "description": "Recommended model tier"
    }
  }
}
