{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tuanle96/agent-harness-kit/main/src/templates/.harness/schemas/explain-block-record.schema.json",
  "title": "agent-harness-kit explain block record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "status",
    "cwd",
    "blockedBy",
    "sourceRule",
    "taskId",
    "featureId",
    "runtime",
    "missingFiles",
    "missingFields",
    "nextCommand",
    "overridePolicy",
    "details"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "mode": { "enum": ["last-block", "task", "permission", "evidence", "bypass", "readiness"] },
    "status": { "enum": ["passed", "failed", "attention"] },
    "cwd": { "type": "string", "minLength": 1 },
    "blockedBy": { "type": "string" },
    "sourceRule": { "type": "string" },
    "taskId": { "type": "string" },
    "featureId": { "type": "string" },
    "fingerprint": { "type": "string" },
    "runtime": { "type": "string", "minLength": 1 },
    "missingFiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "missingFields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "nextCommand": { "type": "string" },
    "overridePolicy": { "type": "string", "minLength": 1 },
    "details": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
