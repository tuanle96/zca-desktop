{
  "schemaVersion": 1,
  "id": "nextjs-no-server-secret-in-client",
  "description": "Client-visible Next.js surfaces must not read server-only environment variables.",
  "kind": "forbid-pattern",
  "severity": "block",
  "owner": "security-reviewer",
  "failureClass": "architecture-drift",
  "prevention": "structural-rule",
  "strictnessTier": "standard",
  "appliesTo": [
    "components/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "src/components/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "src/ui/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "app/**/client/**/*.{ts,tsx,js,jsx,mjs,cjs}"
  ],
  "allowPaths": ["src/config/**", "src/env.*", "src/providers/**", "src/server/**"],
  "forbiddenPatterns": [
    {
      "id": "server-env-var",
      "regex": "\\bprocess\\.env\\.(?!NEXT_PUBLIC_)[A-Z0-9_]+\\b",
      "message": "Client-visible code may only read NEXT_PUBLIC_* values; server secrets belong behind config/service boundaries."
    }
  ],
  "examples": {
    "pass": [
      {
        "path": "components/UserMenu.tsx",
        "content": "\"use client\";\nexport const publicUrl = process.env.NEXT_PUBLIC_APP_URL;"
      }
    ],
    "fail": [
      {
        "path": "components/UserMenu.tsx",
        "content": "\"use client\";\nexport const secret = process.env.STRIPE_SECRET_KEY;"
      }
    ]
  }
}
