{
  "schemaVersion": 1,
  "policyVersion": 1,
  "status": "pre-1.0-stable",
  "versioning": {
    "currentCompatibilityMajor": 1,
    "compatibleChanges": [
      "add optional fields",
      "add enum values only when readers ignore unknown values",
      "tighten documentation without changing validation semantics"
    ],
    "breakingChanges": [
      "remove or rename fields",
      "make an optional field required",
      "change field type or meaning",
      "tighten validation for records already accepted by a released version"
    ]
  },
  "migration": {
    "requiredForBreakingChanges": true,
    "mustPreserveReadability": true,
    "migrationDir": ".harness/schema-migrations",
    "rollbackRequired": true
  },
  "deprecation": {
    "minimumNoticeDays": 90,
    "minimumMinorReleases": 2,
    "removalRequiresMajor": true
  },
  "changelog": {
    "requiredForPackageRelease": true,
    "requiredSection": "Schema Compatibility",
    "breakingChangeLabels": ["Breaking schema change", "Migration", "Deprecation"]
  },
