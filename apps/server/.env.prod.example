# Production env for docker-compose.prod.yml.
# Copy to `.env` and fill in real values, then:
#   docker compose -f docker-compose.prod.yml up -d --build
# Do NOT commit the filled-in `.env` — it holds secrets.

# ── Required ──────────────────────────────────────────────────────────────────
# External Postgres connection string.
DATABASE_URL=postgres://USER:PASSWORD@db-host:5432/zca_cloud

# Public URL clients + login-code emails use to reach this server.
ZCA_CLOUD_PUBLIC_BASE_URL=https://cloud.example.com

# Encryption seed — strong & unique, MINIMUM 32 characters (the server refuses to
# start otherwise, and rejects the built-in dev placeholder). Generate e.g.:
#   openssl rand -base64 48
# Changing this later makes already-stored data unreadable.
ZCA_CLOUD_MASTER_KEY=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARS

# External S3-compatible object storage.
ZCA_CLOUD_S3_BUCKET=zca-cloud-prod
# The endpoint carries the region (the server has no separate region setting):
#   AWS  -> https://s3.ap-southeast-1.amazonaws.com
#   R2   -> https://<account>.r2.cloudflarestorage.com
#   MinIO-> https://minio.example.com
ZCA_CLOUD_S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Email delivery of login codes (strongly recommended) ──────────────────────
# Without SMTP (or a webhook) users can't receive their login code.
ZCA_CLOUD_SMTP_ADDR=smtp.example.com:587
ZCA_CLOUD_MAGIC_LINK_FROM=ZCA Cloud <no-reply@example.com>
# SMTP uses STARTTLS (port 587) or implicit TLS (port 465) by default, plus SMTP
# AUTH when credentials are set. Set ZCA_CLOUD_SMTP_TLS=0 ONLY for a trusted
# plaintext relay on localhost.
ZCA_CLOUD_SMTP_USERNAME=
ZCA_CLOUD_SMTP_PASSWORD=
# ZCA_CLOUD_SMTP_TLS=1

# ── Optional ──────────────────────────────────────────────────────────────────
# Browser CORS allow-list (comma-separated origins). Leave unset for the desktop
# client — it calls the API from a native HTTP client, which is not subject to CORS,
# so no permissive CORS headers are emitted. Only set this if a browser app must
# call the API cross-origin, e.g.:
# ZCA_CLOUD_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# ZCA_CLOUD_PORT=37880                       # host port to publish (container is 37880)
# ZCA_CLOUD_S3_ALLOW_HTTP=0                  # set 1 only for plain-HTTP S3 (e.g. internal MinIO)
# ZCA_CLOUD_MAGIC_LINK_WEBHOOK_URL=          # alternative to SMTP for delivering codes
# ZCA_CLOUD_MAGIC_LINK_TTL_SECS=600
# ZCA_CLOUD_MAGIC_LINK_RATE_LIMIT=5
# ZCA_CLOUD_MAGIC_LINK_RATE_WINDOW_SECS=900
# ZCA_CLOUD_MEDIA_MIRROR_MAX_BYTES=26214400  # 25 MiB
